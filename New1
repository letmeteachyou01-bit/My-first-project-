<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUMIÈRE | Fine Dining Restaurant</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* --- VARIABLES --- */
        :root {
            --gold: #D4AF37;
            --gold-light: #F3E5AB;
            --gold-dark: #AA8C2C;
            --dark: #0a0a0a;
            --dark-secondary: #141414;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --white: #ffffff;
            --text-gray: #999;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--dark);
            color: var(--white);
            overflow-x: hidden;
        }

        h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }
        .heading-font { font-family: 'Cinzel', serif; }
        
        a { text-decoration: none; color: inherit; transition: all 0.4s ease; }
        ul { list-style: none; }

        /* --- NAVIGATION --- */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 8%;
            z-index: 1000;
            transition: 0.4s;
            background: transparent;
        }

        nav.scrolled {
            background: rgba(10, 10, 10, 0.85);
            backdrop-filter: blur(15px);
            padding: 1rem 8%;
            border-bottom: 1px solid var(--glass-border);
        }

        .logo {
            font-family: 'Cinzel', serif;
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: 4px;
            color: var(--gold);
            text-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
        }

        .nav-links {
            display: flex;
            gap: 3rem;
            align-items: center;
        }

        .nav-links a {
            font-size: 0.85rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -5px;
            left: 0;
            background-color: var(--gold);
            transition: 0.3s;
        }

        .nav-links a:hover::after { width: 100%; }
        .nav-links a:hover { color: var(--gold); }

        .book-btn {
            border: 1px solid var(--gold);
            padding: 0.7rem 1.8rem;
            color: var(--gold);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 2px;
        }

        .book-btn:hover {
            background: var(--gold);
            color: var(--dark);
            box-shadow: 0 0 25px rgba(212, 175, 55, 0.4);
        }

        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--white); }

        /* --- HERO SECTION --- */
        .hero {
            height: 100vh;
            background: linear-gradient(to bottom, rgba(0,0,0,0.4), var(--dark)),
                        url('https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .hero-subtitle {
            font-family: 'Cinzel', serif;
            color: var(--gold);
            letter-spacing: 8px;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            opacity: 0;
            animation: fadeInUp 1s forwards 0.5s;
        }

        .hero h1 {
            font-size: 5.5rem;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeInUp 1s forwards 0.8s;
        }

        .hero p {
            max-width: 550px;
            font-size: 1.1rem;
            font-weight: 300;
            color: #ccc;
            margin-bottom: 3rem;
            opacity: 0;
            animation: fadeInUp 1s forwards 1.1s;
        }

        .hero-btn {
            padding: 1rem 3rem;
            background: var(--gold);
            border: none;
            color: var(--dark);
            text-transform: uppercase;
            letter-spacing: 3px;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            opacity: 0;
            animation: fadeInUp 1s forwards 1.4s;
        }

        .hero-btn:hover {
            background: var(--white);
            box-shadow: 0 0 30px rgba(255,255,255,0.3);
        }

        /* --- SECTIONS GENERAL --- */
        section { padding: 7rem 10%; position: relative; }

        .section-header { text-align: center; margin-bottom: 5rem; }

        .section-title {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .section-subtitle {
            color: var(--gold);
            font-family: 'Cinzel', serif;
            letter-spacing: 4px;
            text-transform: uppercase;
            font-size: 0.85rem;
            display: block;
            margin-bottom: 10px;
        }

        .divider {
            width: 80px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin: 0 auto;
        }

        /* --- ABOUT SECTION --- */
        .about-section {
            background: var(--dark-secondary);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }

        .about-img-wrap {
            position: relative;
            overflow: hidden;
            height: 650px;
        }

        .about-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.6s;
        }

        .about-img-wrap:hover .about-img { transform: scale(1.08); }

        .about-img-wrap::after {
            content: '';
            position: absolute;
            top: 20px; left: 20px; right: 20px; bottom: 20px;
            border: 1px solid var(--gold);
            pointer-events: none;
        }

        .about-content {
            padding: 5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #0f0f0f;
        }

        .about-content h3 { 
            font-size: 2.8rem; 
            margin-bottom: 1.5rem; 
            line-height: 1.2;
        }
        
        .about-content h3 span { color: var(--gold); }

        .about-content p { 
            color: var(--text-gray); 
            margin-bottom: 1.5rem; 
            font-weight: 300;
            font-size: 1.05rem;
            line-height: 1.8;
        }

        .signature {
            margin-top: 2rem;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            color: var(--gold);
        }

        /* --- MENU SECTION --- */
        .menu-section { background: var(--dark); }

        .menu-wrapper {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 4rem;
        }

        .menu-column h3 {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--gold);
            margin-bottom: 2.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--glass-border);
            letter-spacing: 2px;
        }

        .menu-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px dotted rgba(255,255,255,0.1);
        }

        .menu-item:last-child { border-bottom: none; }

        .menu-item-left { flex: 1; }

        .dish-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            margin-bottom: 0.4rem;
            color: var(--white);
        }

        .dish-desc {
            color: var(--text-gray);
            font-size: 0.85rem;
            font-style: italic;
            line-height: 1.5;
        }

        .dish-price {
            color: var(--gold);
            font-family: 'Cinzel', serif;
            font-size: 1.2rem;
            font-weight: 600;
            white-space: nowrap;
            margin-left: 1.5rem;
        }

        .dish-dots {
            flex: 1;
            border-bottom: 1px dotted #444;
            margin: 0 1rem;
            position: relative;
            top: -5px;
        }

        /* --- CHEF'S SPECIALS --- */
        .specials-section {
            background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)),
                        url('https://images.unsplash.com/photo-1559339352-11d035aa65de?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-attachment: fixed;
        }

        .specials-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .special-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            padding: 0;
            border-radius: 4px;
            overflow: hidden;
            transition: 0.4s;
        }

        .special-card:hover {
            transform: translateY(-10px);
            border-color: var(--gold);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .special-img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .special-content {
            padding: 2rem;
            text-align: center;
        }

        .special-tag {
            display: inline-block;
            background: var(--gold);
            color: var(--dark);
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 0.3rem 1rem;
            margin-bottom: 1rem;
        }

        .special-name {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .special-price {
            color: var(--gold);
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            margin-top: 1rem;
        }

        /* --- GALLERY --- */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-template-rows: repeat(2, 300px);
            gap: 8px;
        }

        .gallery-item {
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .gallery-item img { 
            width: 100%; 
            height: 100%; 
            object-fit: cover; 
            transition: 0.6s; 
        }
        
        .gallery-item:hover img { transform: scale(1.15); }

        .gallery-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.6);
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: 0.3s;
        }

        .gallery-item:hover .gallery-overlay { opacity: 1; }
        .gallery-overlay i { color: var(--gold); font-size: 2rem; }

        .gallery-item:first-child { grid-column: span 2; grid-row: span 2; }

        /* --- RESERVATION --- */
        .reservation {
            background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)),
                        url('https://images.unsplash.com/photo-1550966871-3ed3c47e2ce2?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-attachment: fixed;
            text-align: center;
        }

        .reservation-form {
            max-width: 700px;
            margin: 0 auto;
            background: rgba(20, 20, 20, 0.9);
            backdrop-filter: blur(20px);
            padding: 4rem;
            border: 1px solid var(--glass-border);
        }

        .form-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .form-group { text-align: left; }

        .form-group label {
            display: block;
            color: var(--gold);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        input, select, textarea {
            width: 100%;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid #333;
            color: var(--white);
            font-family: 'Lato', sans-serif;
            font-size: 0.95rem;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--gold);
            background: rgba(255, 255, 255, 0.08);
        }

        .submit-btn {
            width: 100%;
            padding: 1.2rem;
            background: var(--gold);
            color: var(--dark);
            border: none;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 3px;
            cursor: pointer;
            margin-top: 1rem;
            transition: 0.3s;
            font-size: 0.9rem;
        }

        .submit-btn:hover { 
            background: var(--white); 
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.4);
        }

        /* --- FOOTER --- */
        footer {
            background: #050505;
            padding: 5rem 10% 2rem;
            text-align: center;
            border-top: 1px solid #1a1a1a;
        }

        .footer-logo {
            font-family: 'Cinzel', serif;
            font-size: 2.5rem;
            color: var(--gold);
            margin-bottom: 2rem;
            display: inline-block;
            letter-spacing: 4px;
        }

        .footer-info {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-bottom: 3rem;
            text-align: center;
        }

        .footer-info h4 {
            color: var(--gold);
            font-family: 'Cinzel', serif;
            margin-bottom: 1rem;
            letter-spacing: 2px;
        }

        .footer-info p { color: #666; font-size: 0.9rem; line-height: 1.8; }

        .social-icons { margin-bottom: 2rem; }
        .social-icons a {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            width: 45px;
            height: 45px;
            border: 1px solid #333;
            border-radius: 50%;
            color: var(--white);
            font-size: 1.1rem;
            margin: 0 8px;
            transition: 0.3s;
        }
        .social-icons a:hover { 
            border-color: var(--gold
